# API 서버 포트 (프론트 vite.config.js 의 proxy 대상과 일치)
PORT=4600

# CORS 허용 오리진 (프론트 dev 서버)
CORS_ORIGIN=http://localhost:4599

# --- 향후 연동용 (현재 미사용) ---
# DATABASE_URL=postgres://user:pass@localhost:5432/hpr
# ANTHROPIC_API_KEY=sk-ant-...        # AI 웰스 어드바이저 (Claude API)
# TRANCHING_API_BASE=https://...      # 한화 대체자산 공급망
# JWT_SECRET=change-me                # 폐쇄형 가문 인증
