# API 서버 포트 (프론트 vite.config.js 의 proxy 대상과 일치)
PORT=4600

# CORS 허용 오리진 (프론트 dev 서버)
CORS_ORIGIN=http://localhost:4599

# --- 네이버 로그인 OAuth 2.0 (실연동) ---
# 네이버 개발자센터(https://developers.naver.com)에서 애플리케이션 등록 후 발급.
# 미설정 시 프론트는 데모 모드로 동작(실제 네이버 호출 없이 로그인 흐름만 유지).
# Callback URL 은 네이버 개발자센터에 등록한 값과 반드시 일치해야 한다.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:4599/api/auth/naver/callback

# --- 향후 연동용 (현재 미사용) ---
# DATABASE_URL=postgres://user:pass@localhost:5432/hpr
# ANTHROPIC_API_KEY=sk-ant-...        # AI 웰스 어드바이저 (Claude API)
# TRANCHING_API_BASE=https://...      # 한화 대체자산 공급망
# JWT_SECRET=change-me                # 폐쇄형 가문 인증
