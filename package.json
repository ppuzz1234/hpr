{
  "name": "hanwha-private-room",
  "private": true,
  "version": "0.1.0",
  "description": "PLUS Private Room — B2B 폐쇄형 멀티패밀리오피스 플랫폼 (React + Node.js monorepo)",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm run dev -w frontend",
    "dev:api": "npm run dev -w backend",
    "build": "npm run build -w frontend",
    "start:api": "npm run start -w backend",
    "preview": "npm run preview -w frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
